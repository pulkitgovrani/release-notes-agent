# Copy to .env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...           # PAT with repo read access
GITHUB_REPO=owner/repo         # default repo (can override with --repo)

# NVIDIA NIM (optional) — open models via your NVIDIA key (no Claude). Get one at build.nvidia.com.
# LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Local model (optional) — free, no API key. Requires Ollama running + model pulled.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma3n:e4b
# OLLAMA_HOST=http://localhost:11434
