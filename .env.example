# Copy to .env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...           # PAT with repo read access
GITHUB_REPO=owner/repo         # default repo (can override with --repo)

# Local model (optional) — free, no API key. Requires Ollama running + model pulled.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma3n:e4b
# OLLAMA_HOST=http://localhost:11434
